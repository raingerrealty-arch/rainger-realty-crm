generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id                 String      @id @default(cuid())
  leadId             String      @unique
  fullName           String
  phone              String
  email              String?
  project            String
  source             String
  budget             String?
  notes              String?
  status             String      @default("New")
  temperature        String      @default("Warm")
  assignedTo         String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  city               String?
  country            String?
  nextFollowUpDate   DateTime?
  propertyInterested String?
  propertyType       String?
  purpose            String?
  quotedPrice        String?
  unitPrice          String?
  callLogs           CallLog[]
  siteVisits         SiteVisit[]
}

model CallLog {
  id              String   @id @default(cuid())
  leadId          String
  callDate        DateTime @default(now())
  outcome         String
  summary         String
  siteVisitResult String?
  createdAt       DateTime @default(now())
  lead            Lead     @relation(fields: [leadId], references: [id])
}

model SiteVisit {
  id        String   @id @default(cuid())
  leadId    String
  visitDate DateTime
  visitTime String
  executive String
  status    String   @default("Scheduled")
  notes     String?
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id])
}

model Settings {
  id                String   @id @default(cuid())
  companyName       String
  logo              String?
  elevenlabsAgentId String?
  elevenlabsWebhook String?
  makeWebhook       String?
  createdAt         DateTime @default(now())
}
